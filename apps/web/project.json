{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "tags": ["scope:web", "type:app"],
  "targets": {
    "serve": {
      "command": "vite --host 0.0.0.0",
      "options": {
        "cwd": "apps/web"
      }
    },
    "build": {
      "command": "vite build",
      "options": {
        "cwd": "apps/web"
      }
    },
    "typecheck": {
      "command": "tsc -p apps/web/tsconfig.json --noEmit"
    }
  }
}
